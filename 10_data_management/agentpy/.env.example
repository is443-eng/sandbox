# Ollama Cloud (required for cloud model)
OLLAMA_API_KEY=
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=nemotron-3-nano:30b-cloud

# Optional: Serper (https://serper.dev) for CrewAI SerperDevTool — web_search + server preflight; without it, preflight says search disabled
# SERPER_API_KEY=

# Optional: minimum LLM rounds before END_BRIEF is accepted (capped at MAX_AUTONOMOUS_TURNS). If unset: 2 when SERPER_API_KEY is set, else 1.
# AGENT_MIN_COMPLETION_TURNS=2

# Optional: automatic web preflight before the LLM (1 search, counts toward MAX_WEB_SEARCHES_PER_REQUEST). Set 0 to disable.
# AGENT_PREFETCH_WEB_SEARCH=1

# Optional: before the first LLM call on a new session, run read_skill once and inject assistant+tool messages (default on). Set 0 to disable.
# AGENT_FORCE_FIRST_TOOL=1
# AGENT_FORCE_FIRST_SKILL=disaster_situational_brief.md

# Optional: cap completion length for faster class demos
# AGENT_MAX_OUTPUT_TOKENS=1024

# Optional: turn trace log (default logs/agent.log under this folder if unset). Set 0/off/false/no or empty to disable.
# AGENT_LOG_FILE=
# AGENT_LOG_LEVEL=INFO

# Optional: deployed base URL for python testme.py (smoke test after deploy)
# AGENT_PUBLIC_URL=https://your-connect-server.com/content/your-id

# --- Posit Connect: CLI deploy (manifestme.sh / deployme.sh) ---
# Copy this file to .env and fill in values. Do not commit .env.
#
# School or self-hosted Connect (recommended for FastAPI + rsconnect-python):
#   CONNECT_SERVER = rsconnect API base (scheme + host, usually no path). Example (Cornell Systems):
#     https://connect.systems-apps.com
#   The browser may show .../connect/#/content/listing — strip # and everything after; do not append /connect
#   if rsconnect returns 404 on server_settings (wrong URL shape).
#   CONNECT_API_KEY = create under Connect: your profile / Account -> API Keys.
# Posit Connect Cloud often uses Posit Publisher instead of API keys; for API key deploy,
# prefer your institution's Connect URL when available.
#
# CONNECT_SERVER=
# CONNECT_API_KEY=
# CONNECT_TITLE=course-autonomous-agent
# Optional: set to 1 if rsconnect fails TLS verification (some proxies)
# CONNECT_INSECURE=1
# Optional: viewer key if testme.py must call authenticated content
# CONNECT_VIEWER_KEY=

# After a successful deploy: set the content's public base URL (no trailing slash) for smoke tests.
# AGENT_PUBLIC_URL=https://your-connect-server.com/content/xxxxxxxx

# --- After deploy (set in Connect UI for this content, not only in .env) ---
# On the server: OLLAMA_API_KEY, OLLAMA_HOST, OLLAMA_MODEL, optional SERPER_API_KEY
# so the agent can call Ollama and search in production.
